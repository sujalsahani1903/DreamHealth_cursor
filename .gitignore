# OS & editors
.DS_Store
Thumbs.db
*.log
.idea/
.vscode/
.cursor/

# Secrets — never commit
.env
.env.*
!.env.example
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
backend/.venv/
backend/venv/
*.egg-info/
.eggs/
dist/
build/

# Backend uploads (keep folder, ignore user files)
backend/uploads/*
!backend/uploads/.gitkeep

# Node / frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/
coverage/
*.tsbuildinfo

# DB dumps & local backups
*.sql.gz
*.dump
